# Backend Environment Variables
DEBUG=True
ENV=development

# Database
DATABASE_URL=sqlite:///./chess.db
# For PostgreSQL: postgresql://user:password@localhost/chess_db

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Chess Engine
MAX_TRANSPOSITION_TABLE_SIZE=1000000
DEFAULT_AI_DEPTH=5
MAX_AI_SEARCH_TIME=3.0
QUIESCENCE_DEPTH=3

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_TIMEOUT=60

# ELO Ratings
ELO_K_FACTOR=32
MIN_ELO=400
MAX_ELO=3000

# CORS (in production, set to specific domains)
ALLOW_ORIGINS=["*"]
